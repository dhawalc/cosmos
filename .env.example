# ==============================================================
# COSMOS — Environment Variables
# ==============================================================
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.
# ==============================================================

# --- PRIMARY LLM: Anthropic Claude ---
# Get your key at: https://console.anthropic.com/
# Model used: claude-haiku-4-5
ANTHROPIC_API_KEY=

# --- FALLBACK LLM: Google Gemini ---
# Get your key at: https://aistudio.google.com/app/apikey  (FREE tier available)
# Model used: gemini-2.0-flash
GEMINI_API_KEY=

# --- OPTIONAL: Real Astrology API ---
# Free tier at: https://freeastrologyapi.com/
# Leave blank to use the built-in deterministic engine (works without a key)
FREE_ASTROLOGY_API_KEY=

# --- OPTIONAL: OpenCage Geocoding ---
# Free tier (2,500 req/day) at: https://opencagedata.com/
# Leave blank to use the built-in mock (defaults to New Delhi coordinates)
OPENCAGE_API_KEY=
