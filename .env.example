# ==============================================================
# COSMOS — Environment Variables
# ==============================================================
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.
# ==============================================================

# --- PRIMARY LLM: Anthropic Claude ---
# Get your key at: https://console.anthropic.com/
# Model used: claude-haiku-4-5
ANTHROPIC_API_KEY=

# --- FALLBACK LLM: Google Gemini ---
# Get your key at: https://aistudio.google.com/app/apikey  (FREE tier available)
# Model used: gemini-2.0-flash
GEMINI_API_KEY=

# --- SUPABASE (Database) ---
# Create a free project at: https://supabase.com/
# Then run supabase-schema.sql in the SQL Editor
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
